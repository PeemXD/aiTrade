APP_ENV=local
APP_PORT=8080
LOG_LEVEL=debug

DATABASE_URL=postgres://postgres:postgres@localhost:5432/polymarket_bot?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=ai-trade-local
KAFKA_CONSUMER_GROUP_FETCH=polymarket-fetch-data-service-local
KAFKA_CONSUMER_GROUP_PROCESS=polymarket-process-service-local
KAFKA_AUTO_CREATE_TOPICS=true

EVENT_BUS=kafka
NATS_URL=nats://localhost:4222

DASHBOARD_SSE_ENABLED=true
DASHBOARD_SSE_HEARTBEAT_SECONDS=15
DASHBOARD_MARKET_THROTTLE_MS=1000

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

NEWS_GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
NEWS_POLL_INTERVAL_SECONDS=60
NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://www.sec.gov/news/pressreleases.rss
NEWS_GDELT_QUERY="(bitcoin OR ethereum OR crypto OR SEC OR fed OR election OR sports) sourcelang:English"
NEWS_MARKET_MATCH_THRESHOLD=0.70
MAX_AI_MATCHES_PER_ARTICLE=3

AI_PROVIDER=openai_compatible
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.1
AI_TIMEOUT_SECONDS=60
AI_RATE_LIMIT_PER_MINUTE=30

MARKET_MIN_VOLUME_USD=50000
MARKET_MAX_SPREAD=0.05
MARKET_MIN_LIQUIDITY_USD=10000
MARKET_MIN_HOURS_TO_EXPIRY=12
MAX_SUBSCRIBED_MARKETS=50

EDGE_THRESHOLD=0.05
MIN_SIGNAL_CONFIDENCE=0.65

MAX_POSITION_PER_MARKET_PCT=0.05
MAX_CATEGORY_EXPOSURE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_TOTAL_OPEN_POSITIONS=10
MAX_ORDERBOOK_IMPACT_PCT=0.02
KELLY_FRACTION=0.25

PAPER_STARTING_BALANCE_USD=10000
EXECUTION_MODE=paper

TAKE_PROFIT_PCT=0.20
STOP_LOSS_PCT=0.10
EXIT_BEFORE_EXPIRY_HOURS=6
LIVE_LOOP_INTERVAL_SECONDS=60

ENABLE_REAL_TRADING=false
REAL_TRADING_CONFIRMATION=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
